{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:IBM Plex Mono|IBM Plex Sans))/i]",
        "message": "Font not provided by the design system. Available: IBM Plex Mono, IBM Plex Sans."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|children|style|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: variant, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:neutral|brand|truth|solid)$/]",
        "message": "<Badge> variant must be one of 'neutral' | 'brand' | 'truth' | 'solid'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:solid|outline|ghost)$/]",
        "message": "<Button> variant must be one of 'solid' | 'outline' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='DiagramNode'] > JSXAttribute > JSXIdentifier[name!=/^(?:kind|label|size|style|key|ref|className|style|children)$/]",
        "message": "<DiagramNode> doesn't accept that prop. Declared props: kind, label, size, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='DiagramNode'] > JSXAttribute[name.name='kind'] > Literal[value!=/^(?:default|key)$/]",
        "message": "<DiagramNode> kind must be one of 'default' | 'key'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Eyebrow'] > JSXAttribute > JSXIdentifier[name!=/^(?:index|label|children|style|key|ref|className|style|children)$/]",
        "message": "<Eyebrow> doesn't accept that prop. Declared props: index, label, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='GreenWave'] > JSXAttribute > JSXIdentifier[name!=/^(?:intersections|width|height|showLabels|bandColor|style|key|ref|className|style|children)$/]",
        "message": "<GreenWave> doesn't accept that prop. Declared props: intersections, width, height, showLabels, bandColor, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='MetricBlock'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|unit|label|caption|align|style|key|ref|className|style|children)$/]",
        "message": "<MetricBlock> doesn't accept that prop. Declared props: value, unit, label, caption, align, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='MetricBlock'] > JSXAttribute[name.name='align'] > Literal[value!=/^(?:left|center)$/]",
        "message": "<MetricBlock> align must be one of 'left' | 'center'."
      },
      {
        "selector": "JSXOpeningElement[name.name='PhaseChip'] > JSXAttribute > JSXIdentifier[name!=/^(?:phase|seconds|showLabel|style|key|ref|className|style|children)$/]",
        "message": "<PhaseChip> doesn't accept that prop. Declared props: phase, seconds, showLabel, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProgressBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:current|total|style|key|ref|className|style|children)$/]",
        "message": "<ProgressBar> doesn't accept that prop. Declared props: current, total, style."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
  "x-omelette": {
    "components": {
      "Badge": {
        "replaces": []
      },
      "Button": {
        "replaces": []
      },
      "DiagramNode": {
        "replaces": []
      },
      "Eyebrow": {
        "replaces": []
      },
      "GreenWave": {
        "replaces": []
      },
      "MetricBlock": {
